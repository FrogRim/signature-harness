{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frogrim.local/signature-harness/failure_taxonomy.schema.json",
  "title": "Signature Harness Failure Taxonomy",
  "type": "object",
  "required": ["failure_types"],
  "properties": {
    "failure_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "severity", "retriable", "recovery_action", "owner", "evidence_required", "user_visible_message"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "retriable": {"type": "boolean"},
          "recovery_action": {"type": "string"},
          "owner": {"type": "string"},
          "evidence_required": {"type": "array", "items": {"type": "string"}},
          "user_visible_message": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
