{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frogrim.local/signature-harness/architecture_candidate.schema.json",
  "title": "Signature Harness Architecture Candidate",
  "type": "object",
  "required": [
    "schema",
    "id",
    "status",
    "application_mode",
    "scope",
    "summary",
    "evidence",
    "proposed_changes",
    "compatibility",
    "verification"
  ],
  "properties": {
    "schema": {"const": "sh.architecture_candidate.v1"},
    "id": {"type": "string"},
    "status": {"const": "candidate"},
    "application_mode": {"const": "candidate_only"},
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "summary": {"type": "string"},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "observation"],
        "properties": {
          "path": {"type": "string"},
          "line": {"type": "integer", "minimum": 1},
          "observation": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "proposed_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "target", "reason"],
        "properties": {
          "action": {"type": "string"},
          "target": {"type": "string"},
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["codex", "claude", "agent_teams_dependency"],
      "properties": {
        "codex": {"type": "string"},
        "claude": {"type": "string"},
        "agent_teams_dependency": {"type": "string"}
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["commands", "oracle_criteria"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "oracle_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "residual_risks": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}
