{
  "tools": [
    {
      "name": "init-state",
      "description": "Create the .sh directory skeleton used by Signature Harness runtime artifacts.",
      "inputSchema": {"type": "object", "required": ["root"], "properties": {"root": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "root", "created"]},
      "exit_codes": {"0": "state directories created or already present", "2": "invalid root or write failure"},
      "retryability": "idempotent",
      "timeout_sec": 5,
      "side_effect_class": "workspace_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/"],
      "failure_modes": ["CONTRACT_VIOLATION"]
    },
    {
      "name": "validate-transition",
      "description": "Validate a state-machine event against the canonical transition map.",
      "inputSchema": {"type": "object", "required": ["from_state", "event"], "properties": {"from_state": {"type": "string"}, "event": {"type": "string"}, "to_state": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "from_state", "event"]},
      "exit_codes": {"0": "transition valid", "2": "transition invalid"},
      "retryability": "not_needed",
      "timeout_sec": 3,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["CONTRACT_VIOLATION"]
    },
    {
      "name": "hash-manifest",
      "description": "Compute drift and evidence hashes from explicit target files and evidence assets.",
      "inputSchema": {"type": "object", "required": ["manifest"], "properties": {"manifest": {"type": "string"}, "root": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "drift_hash", "evidence_hash", "evidence_assets"]},
      "exit_codes": {"0": "hashes generated", "2": "manifest invalid or target escapes root"},
      "retryability": "idempotent",
      "timeout_sec": 30,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["MISSING_CONTEXT", "ARTIFACT_MISMATCH"]
    },
    {
      "name": "validate-resume",
      "description": "Validate an allowlisted resume-check contract and blocked receipt binding without executing it.",
      "inputSchema": {"type": "object", "required": ["contract"], "properties": {"contract": {"type": "string"}, "receipt": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "status"]},
      "exit_codes": {"0": "contract accepted", "3": "security rejection"},
      "retryability": "contract_repair_required",
      "timeout_sec": 5,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["UNSAFE_RESUME", "CONTRACT_VIOLATION"]
    },
    {
      "name": "validate-workflow-evidence",
      "description": "Validate dynamic workflow completion records and artifact-backed evidence.",
      "inputSchema": {"type": "object", "required": ["evidence"], "properties": {"evidence": {"type": "string"}, "root": {"type": "string"}, "require_artifacts": {"type": "boolean"}, "allow_descriptive_evidence": {"type": "boolean"}, "evidence_manifest": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "completion_allowed", "recommended_oracle_verdict"]},
      "exit_codes": {"0": "completion eligible", "2": "schema invalid", "5": "schema valid but incomplete"},
      "retryability": "gap_fill_required",
      "timeout_sec": 10,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["INVALID_EVIDENCE", "ARTIFACT_MISMATCH"]
    },
    {
      "name": "validate-completion-artifact",
      "description": "Validate Completion Auditor artifacts for external-runner hang and remediation evidence without executing the SUT.",
      "inputSchema": {"type": "object", "required": ["artifact"], "properties": {"artifact": {"type": "string"}, "max_retries": {"type": "integer"}}},
      "outputSchema": {"type": "object", "required": ["ok", "kind", "status", "recommended_oracle_verdict", "recommended_state"]},
      "exit_codes": {"0": "artifact valid and no fail-closed gate required", "2": "artifact schema invalid", "5": "valid artifact requires INCOMPLETE/remediation handling", "6": "remediation deadline expired; abort recommended"},
      "retryability": "artifact_or_external_runner_repair_required",
      "timeout_sec": 5,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["SUT_HANG_TIMEOUT", "REMEDIATION_TIMEOUT", "INVALID_EVIDENCE", "CONTRACT_VIOLATION"]
    },
    {
      "name": "run-resume",
      "description": "Fail-closed placeholder for sandboxed resume check execution.",
      "inputSchema": {"type": "object", "required": ["contract"], "properties": {"contract": {"type": "string"}, "receipt": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "status"]},
      "exit_codes": {"4": "sandbox adapter unavailable or unsafe contract rejected"},
      "retryability": "blocked_until_sandbox_adapter",
      "timeout_sec": 5,
      "side_effect_class": "blocked_execution",
      "approval_required": true,
      "emitted_artifacts": [],
      "failure_modes": ["UNSAFE_RESUME", "BLOCKED_APPROVAL"]
    },
    {
      "name": "write-directive",
      "description": "Validate a transition and write an orchestration directive with reserved-key protection.",
      "inputSchema": {"type": "object", "required": ["run_id", "from_state", "event"], "properties": {"run_id": {"type": "string"}, "from_state": {"type": "string"}, "event": {"type": "string"}, "to_state": {"type": "string"}, "payload": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "directive"]},
      "exit_codes": {"0": "directive written", "2": "invalid transition or reserved key override"},
      "retryability": "idempotent_for_same_transition",
      "timeout_sec": 5,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/orchestration/directives/<run_id>.json"],
      "failure_modes": ["CONTRACT_VIOLATION"]
    },
    {
      "name": "append-ledger",
      "description": "Append a hash-chained event to the global .sh ledger.",
      "inputSchema": {"type": "object", "required": ["entry"], "properties": {"entry": {"type": "string"}, "root": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "ledger", "entry"]},
      "exit_codes": {"0": "ledger entry appended", "2": "invalid event or reserved hash keys"},
      "retryability": "append_only",
      "timeout_sec": 5,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/ledger.jsonl"],
      "failure_modes": ["CONTRACT_VIOLATION"]
    },
    {
      "name": "verify-ledger",
      "description": "Verify global .sh ledger hash-chain integrity.",
      "inputSchema": {"type": "object", "properties": {"root": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "ledger", "line_count"]},
      "exit_codes": {"0": "ledger valid", "6": "hash-chain integrity failure"},
      "retryability": "not_retriable_without_repair",
      "timeout_sec": 10,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["ARTIFACT_MISMATCH"]
    },
    {
      "name": "start-run",
      "description": "Create a durable run directory and initialize manifest, state, trace, ledger, replay, and handoff artifacts.",
      "inputSchema": {"type": "object", "required": ["goal_id", "seed_id", "active_slice", "objective"], "properties": {"run_id": {"type": "string"}, "goal_id": {"type": "string"}, "seed_id": {"type": "string"}, "active_slice": {"type": "string"}, "objective": {"type": "string"}, "permission_profile": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "run_id", "run_dir"]},
      "exit_codes": {"0": "run initialized", "2": "run exists or invalid id"},
      "retryability": "idempotent_with_new_run_id",
      "timeout_sec": 5,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/runs/<run_id>/run_manifest.json", ".sh/runs/<run_id>/state.json", ".sh/runs/<run_id>/trace.jsonl"],
      "failure_modes": ["CONTRACT_VIOLATION"]
    },
    {
      "name": "resume-run",
      "description": "Resume a paused or blocked run with the same run id and append recovery trace.",
      "inputSchema": {"type": "object", "required": ["run_id"], "properties": {"run_id": {"type": "string"}, "reason": {"type": "string"}, "event": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "run_id", "transition"]},
      "exit_codes": {"0": "run resumed", "2": "invalid transition or terminal run"},
      "retryability": "state_dependent",
      "timeout_sec": 5,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/runs/<run_id>/trace.jsonl", ".sh/ledger.jsonl"],
      "failure_modes": ["CONTRACT_VIOLATION", "NEEDS_HUMAN_DECISION"]
    },
    {
      "name": "record-step",
      "description": "Record a trace event, tool call row, cost/latency aggregate, artifact index, state update, and replay snapshot. If state_before and state_after differ, event is required and must match the canonical transition map.",
      "inputSchema": {"type": "object", "required": ["run_id", "step_id", "operation_name", "state_before", "state_after"], "properties": {"run_id": {"type": "string"}, "step_id": {"type": "string"}, "operation_name": {"type": "string"}, "tool_name": {"type": "string"}, "state_before": {"type": "string"}, "state_after": {"type": "string"}, "event": {"type": "string"}, "artifact": {"type": "array", "items": {"type": "string"}}}},
      "outputSchema": {"type": "object", "required": ["ok", "run_id", "step_id", "trace_event"]},
      "exit_codes": {"0": "step recorded", "2": "state mismatch, invalid state transition, or artifact validation failure"},
      "retryability": "append_only",
      "timeout_sec": 10,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/runs/<run_id>/trace.jsonl", ".sh/runs/<run_id>/tool_calls.jsonl", ".sh/runs/<run_id>/cost_latency.json", ".sh/runs/<run_id>/artifacts.json"],
      "failure_modes": ["ARTIFACT_MISMATCH", "CONTRACT_VIOLATION"]
    },
    {
      "name": "record-interruption",
      "description": "Record a pause, blocked, approval, review, or abort interruption and transition the run.",
      "inputSchema": {"type": "object", "required": ["run_id", "kind", "reason"], "properties": {"run_id": {"type": "string"}, "kind": {"type": "string"}, "reason": {"type": "string"}, "approval_needed": {"type": "boolean"}}},
      "outputSchema": {"type": "object", "required": ["ok", "run_id", "interruption"]},
      "exit_codes": {"0": "interruption recorded", "2": "transition not allowed"},
      "retryability": "append_only",
      "timeout_sec": 5,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/runs/<run_id>/interruptions.json", ".sh/runs/<run_id>/trace.jsonl"],
      "failure_modes": ["NO_PROGRESS", "BLOCKED_APPROVAL", "CONTRACT_VIOLATION"]
    },
    {
      "name": "replay-run",
      "description": "Reconstruct a human-readable and machine-readable run summary from replay and trace artifacts.",
      "inputSchema": {"type": "object", "required": ["run_id"], "properties": {"run_id": {"type": "string"}, "refresh": {"type": "boolean"}}},
      "outputSchema": {"type": "object", "required": ["ok", "run_id", "state", "trace_count"]},
      "exit_codes": {"0": "replay summary produced", "2": "run missing or replay invalid"},
      "retryability": "idempotent",
      "timeout_sec": 5,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["MISSING_CONTEXT"]
    },
    {
      "name": "validate-schemas",
      "description": "Validate repo-local schema presence, tool contracts, failure taxonomy, eval task corpus, and security policy presence.",
      "inputSchema": {"type": "object", "properties": {"root": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "schemas", "evals", "security_policy_present"]},
      "exit_codes": {"0": "schemas and fixtures valid", "2": "schema or fixture contract invalid"},
      "retryability": "repair_required",
      "timeout_sec": 10,
      "side_effect_class": "read_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["CONTRACT_VIOLATION", "BENCHMARK_INFRA_FAILURE"]
    },
    {
      "name": "validate-policy",
      "description": "Evaluate a proposed action against filesystem, network, command, and approval policy.",
      "inputSchema": {"type": "object", "required": ["policy", "action_file"], "properties": {"policy": {"type": "string"}, "action_file": {"type": "string"}, "write_approval_log": {"type": "boolean"}}},
      "outputSchema": {"type": "object", "required": ["ok", "approval_required", "recommended_state"]},
      "exit_codes": {"0": "allowed or explicitly approved", "7": "blocked by permission policy"},
      "retryability": "approval_or_policy_change_required",
      "timeout_sec": 5,
      "side_effect_class": "read_only_or_runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/approvals/<approval_id>.json"],
      "failure_modes": ["PERMISSION_DENIED", "UNSAFE_ACTION", "BLOCKED_APPROVAL"]
    },
    {
      "name": "run-evals",
      "description": "Run deterministic repo-local benchmark or regression fixtures and emit aggregate score, cost, duration, retries, and tool error rate.",
      "inputSchema": {"type": "object", "required": ["suite"], "properties": {"suite": {"type": "string"}, "trials": {"type": "integer"}, "eval_run_id": {"type": "string"}}},
      "outputSchema": {"type": "object", "required": ["ok", "eval_result", "summary"]},
      "exit_codes": {"0": "all trials passed", "8": "one or more trials failed", "2": "invalid suite"},
      "retryability": "fixture_or_runtime_repair_required",
      "timeout_sec": 30,
      "side_effect_class": "runtime_write",
      "approval_required": false,
      "emitted_artifacts": [".sh/evals/<eval_run_id>/eval_result.json", ".sh/evals/<eval_run_id>/transcript_review.md"],
      "failure_modes": ["BENCHMARK_INFRA_FAILURE", "INVALID_EVIDENCE", "NO_PROGRESS"]
    },
    {
      "name": "self-test",
      "description": "Run built-in substrate regression checks for transitions, hash manifests, resume validation, evidence validation, run/replay, policy, evals, and ledger integrity.",
      "inputSchema": {"type": "object", "properties": {}},
      "outputSchema": {"type": "object", "required": ["ok", "self_test"]},
      "exit_codes": {"0": "self-test passed", "1": "assertion or unexpected runtime failure"},
      "retryability": "repair_required",
      "timeout_sec": 30,
      "side_effect_class": "temp_only",
      "approval_required": false,
      "emitted_artifacts": [],
      "failure_modes": ["CONTRACT_VIOLATION", "BENCHMARK_INFRA_FAILURE"]
    }
  ]
}
