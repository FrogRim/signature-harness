{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frogrim.local/signature-harness/run_manifest.schema.json",
  "title": "Signature Harness Run Manifest",
  "type": "object",
  "required": ["run_id", "trace_id", "goal_id", "seed_id", "active_slice", "objective", "status", "created_at", "agent_name", "agent_version", "resource_spec"],
  "properties": {
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
    "trace_id": {"type": "string"},
    "goal_id": {"type": "string"},
    "seed_id": {"type": "string"},
    "active_slice": {"type": "string"},
    "objective": {"type": "string"},
    "vertical": {"type": "string"},
    "permission_profile": {"enum": ["read_only", "workspace_write", "scoped_network", "danger_full_access"]},
    "status": {"enum": ["RUNNING", "GAP_FILL", "RECOVERY", "PAUSED", "BLOCKED", "COMPLETE", "ABORTED"]},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "agent_name": {"type": "string"},
    "agent_version": {"type": "string"},
    "resource_spec": {"type": "object"}
  },
  "additionalProperties": true
}
