{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frogrim.local/signature-harness/trace_event.schema.json",
  "title": "Signature Harness Trace Event",
  "type": "object",
  "required": ["trace_id", "span_id", "run_id", "step_id", "agent_name", "agent_version", "operation_name", "start_ts", "end_ts", "duration_ms", "state_before", "state_after", "approval_needed"],
  "properties": {
    "trace_id": {"type": "string"},
    "span_id": {"type": "string"},
    "parent_span_id": {"type": ["string", "null"]},
    "run_id": {"type": "string"},
    "step_id": {"type": "string"},
    "agent_name": {"type": "string"},
    "agent_version": {"type": "string"},
    "conversation_id": {"type": ["string", "null"]},
    "session_id": {"type": ["string", "null"]},
    "operation_name": {"type": "string"},
    "tool_name": {"type": ["string", "null"]},
    "input_hash": {"type": ["string", "null"]},
    "args_hash": {"type": ["string", "null"]},
    "output_hash": {"type": ["string", "null"]},
    "artifact_hashes": {"type": "array", "items": {"type": "string"}},
    "duration_ms": {"type": "integer", "minimum": 0},
    "token_usage_input": {"type": "integer", "minimum": 0},
    "token_usage_output": {"type": "integer", "minimum": 0},
    "estimated_cost": {"type": "number", "minimum": 0},
    "error_type": {"type": ["string", "null"]},
    "state_before": {"type": "string"},
    "state_after": {"type": "string"},
    "approval_needed": {"type": "boolean"},
    "approval_result": {"type": ["string", "null"]},
    "semconv": {"type": "object"}
  },
  "additionalProperties": true
}
